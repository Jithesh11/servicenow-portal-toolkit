# ServiceNow Portal Toolkit — Credentials
# Copy this file to ~/.servicenow-portal-toolkit/.env
# or run: servicenow-portal-toolkit setup

# Your instance subdomain (e.g. "mycompany" for mycompany.service-now.com)
SNOW_INSTANCE=your-instance-name

# ServiceNow user with read/write access to sp_portal, sp_theme, pa_page_view, sp_log
SNOW_USER=admin

# Password or OAuth token
SNOW_PASS=your-password
